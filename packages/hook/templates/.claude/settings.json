{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by chunk hook repo init. All routing is in .chunk/config.yml.",
  "permissions": {
    "allow": [
      "Bash(chunk:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook run --project ${CLAUDE_PROJECT_DIR:-__PROJECT__}",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook run --project ${CLAUDE_PROJECT_DIR:-__PROJECT__}",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook run --project ${CLAUDE_PROJECT_DIR:-__PROJECT__}",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook run --project ${CLAUDE_PROJECT_DIR:-__PROJECT__}",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook run --project ${CLAUDE_PROJECT_DIR:-__PROJECT__}",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
