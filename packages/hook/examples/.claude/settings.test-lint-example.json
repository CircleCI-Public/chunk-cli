{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Test & lint execs. Configure commands, triggers, and timeouts in .chunk/hook/config.yml.",
  "permissions": {
    "allow": [
      "Bash(chunk:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook scope deactivate --project __PROJECT__",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Shell|run_in_terminal",
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook exec check tests-changed --staged --on pre-commit --matcher 'Bash|Shell|run_in_terminal' --project __PROJECT__",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "TaskUpdate|TodoWrite|manage_todo_list",
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook exec check tests-changed --matcher 'TaskUpdate|TodoWrite|manage_todo_list' --project __PROJECT__",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|replace_string_in_file|create_file|multi_replace_string_in_file",
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook exec run lint --matcher 'Edit|Write|replace_string_in_file|create_file|multi_replace_string_in_file' --project __PROJECT__",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook exec check tests --project __PROJECT__",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook scope deactivate --project __PROJECT__",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
