{
  "commands": [
    {
      "name": "test",
      "run": "task test",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 300,
      "limit": 3,
      "remote": true
    },
    {
      "name": "test-changed",
      "run": "task test -- {{CHANGED_PACKAGES}}",
      "role": "precheck",
      "fileExt": ".go",
      "timeout": 300,
      "limit": 3
    },
    {
      "name": "lint",
      "run": "task lint",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 60,
      "limit": 3
    },
    {
      "name": "format",
      "run": "task fmt",
      "role": "autofix",
      "timeout": 30,
      "limit": 3,
      "always": true
    }
  ],
  "vcs": {
    "org": "CircleCI-Public",
    "repo": "chunk-cli"
  },
  "orgID": "f22b6566-597d-46d5-ba74-99ef5bb3d85c"
}
