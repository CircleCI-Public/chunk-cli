{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by chunk init. Hooks for tests and lint.",
  "permissions": {
    "allow": [
      "Bash(chunk:*)"
    ]
  },
  "env": {
    "CHUNK_HOOK_ENABLE": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook scope activate --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook state append --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "chunk validate test --no-check --on pre-commit --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "chunk validate test-changed --check --on pre-commit --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "chunk validate lint --no-check --on pre-commit --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "chunk validate format --no-check --on pre-commit --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk validate test --check --allow-missing --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "chunk validate lint --check --allow-missing --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "chunk validate format --check --allow-missing --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook scope deactivate --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "chunk hook state clear --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
