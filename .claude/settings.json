{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by chunk hook repo init. Hooks for tests, lint, and code review.",
  "permissions": {
    "allow": [
      "Bash(chunk:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook scope deactivate --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook state save --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook exec check tests-changed --staged --on pre-commit --matcher 'Bash|Shell|run_in_terminal' --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "chunk hook exec run lint --staged --on pre-commit --matcher 'Bash|Shell|run_in_terminal' --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|replace_string_in_file|create_file|multi_replace_string_in_file",
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook exec run format --matcher 'Edit|Write|replace_string_in_file|create_file|multi_replace_string_in_file' --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook sync check exec:tests task:review --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "chunk hook exec run lint --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk hook scope deactivate --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "chunk hook state clear --project ${CLAUDE_PROJECT_DIR:-chunk-cli}",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
