+
+func TestMultiplyTable(t *testing.T) {
+	tests := []struct {
+		a, b, want int
+	}{
+		{2, 3, 6},
+		{0, 5, 0},
+	}
+	for _, tc := range tests {
+		if got := Multiply(tc.a, tc.b); got != tc.want {
+			t.Fatalf("Multiply(%d, %d) = %d, want %d", tc.a, tc.b, got, tc.want)
+		}
+	}
+}
